# ── Intuit app (ONE app authorizes MANY companies) ──────────────────────────
QBO_CLIENT_ID=your_intuit_client_id
QBO_CLIENT_SECRET=your_intuit_client_secret
QBO_ENVIRONMENT=production            # or "sandbox"

# ── Public URL of this server (via the Cloudflare named tunnel; no trailing /) ─
# Used as the OAuth redirect base: <PUBLIC_BASE_URL>/oauth/callback
# This exact callback must be registered in your Intuit app's Redirect URIs.
PUBLIC_BASE_URL=https://qbo-mcp.example.com

# ── Shared bearer token every MCP client must send ───────────────────────────
# Authorization: Bearer <MCP_BEARER_TOKEN>   (also used as ?token= for /connect)
# Generate a long random value, e.g.:  openssl rand -hex 32
MCP_BEARER_TOKEN=replace_with_a_long_random_secret

# ── Cloudflare named-tunnel token (CF Zero Trust → Tunnels → your tunnel) ─────
TUNNEL_TOKEN=your_cloudflare_tunnel_token
